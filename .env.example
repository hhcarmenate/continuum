# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memoria
POSTGRES_USER=memoria
POSTGRES_PASSWORD=memoria

# asyncpg DSN (auto-built if not set)
# DATABASE_URL=postgresql://memoria:memoria@localhost:5432/memoria

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# TTL for hot memory (seconds) — default 24h
REDIS_TTL_SECONDS=86400

# ── MCP Server ────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_LEVEL=INFO

# ── Business rules ───────────────────────────────────────────
# Minimum importance for auto-save without confirmation (1-10)
MIN_IMPORTANCE_AUTO_SAVE=7
